{
  "id": "com.crispai.plugin",
  "name": "CrispAI",
  "version": "0.2.0",
  "manifestVersion": 5,
  "host": {
    "app": "PS",
    "minVersion": "23.0.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "crispai-panel",
      "label": { "default": "CrispAI" },
      "minimumSize": { "width": 200, "height": 120 },
      "defaultSize": { "width": 240, "height": 140 }
    }
  ],
  "requiredPermissions": {
    "network": { "domains": ["localhost"] },
    "localFileSystem": "request"
  }
}
