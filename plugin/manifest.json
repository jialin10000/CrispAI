{
  "id": "com.crispai.plugin",
  "name": "CrispAI",
  "version": "0.2.0",
  "manifestVersion": 5,
  "host": [
    {
      "app": "PS",
      "minVersion": "22.0.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "crispai-panel",
      "label": { "default": "CrispAI" },
      "minimumSize": { "width": 180, "height": 120 }
    }
  ],
  "requiredPermissions": {
    "network": { "domains": ["localhost"] },
    "localFileSystem": "request"
  }
}
